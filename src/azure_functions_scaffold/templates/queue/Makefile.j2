VENV_DIR := .venv
PYTHON := $(VENV_DIR)/bin/python
PIP := $(VENV_DIR)/bin/pip
DEV_EXTRAS := {% if include_ruff or include_mypy or include_pytest %}[dev]{% endif %}
INCLUDE_RUFF := {% if include_ruff %}1{% else %}0{% endif %}
INCLUDE_MYPY := {% if include_mypy %}1{% else %}0{% endif %}
INCLUDE_PYTEST := {% if include_pytest %}1{% else %}0{% endif %}

.PHONY: bootstrap
bootstrap:
	@if [ ! -d "$(VENV_DIR)" ]; then \
		python3 -m venv $(VENV_DIR); \
	fi
	@$(PIP) install --upgrade pip

.PHONY: install
install: bootstrap
	@$(PIP) install -e .$(DEV_EXTRAS)

.PHONY: lint
lint:
ifeq ($(INCLUDE_RUFF),1)
	@$(VENV_DIR)/bin/ruff check .
	@$(VENV_DIR)/bin/ruff format --check .
else
	@echo "No lint tooling configured."
endif

.PHONY: typecheck
typecheck:
ifeq ($(INCLUDE_MYPY),1)
	@$(VENV_DIR)/bin/mypy .
else
	@echo "No type checker configured."
endif

.PHONY: test
test:
ifeq ($(INCLUDE_PYTEST),1)
	@$(VENV_DIR)/bin/pytest
else
	@echo "No test suite configured."
endif

.PHONY: check-all
check-all: lint typecheck test
