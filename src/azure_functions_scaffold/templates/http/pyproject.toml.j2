[build-system]
requires = ["hatchling>=1.27.0"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["app"]

[tool.hatch.build.targets.sdist]
include = [
  "app",
  "tests",
  "function_app.py",
  "host.json",
  "local.settings.json.example",
  "README.md",
  "Makefile",
  "pyproject.toml",
]

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "Azure Functions Python v2 app scaffolded by azure-functions-scaffold."
readme = "README.md"
requires-python = ">={{ python_version }},<{{ python_upper_bound }}"
dependencies = [
  "azure-functions>=1.23.0",
  "azure-functions-logging>=0.5.0",
{% if include_openapi -%}
  "azure-functions-openapi>=0.17.0",
{% endif -%}
{% if include_validation -%}
  "azure-functions-validation>=0.7.0",
{% endif -%}
{% if include_validation -%}
  "pydantic>=2.0.0",
{% endif -%}
{% if include_doctor -%}
  "azure-functions-doctor>=0.16.0",
{% endif -%}
]

[project.optional-dependencies]
dev = [
{% if include_pytest -%}
  "pytest>=8.3.5",
{% endif -%}
{% if include_ruff -%}
  "ruff>=0.11.0",
{% endif -%}
{% if include_mypy -%}
  "mypy>=1.17.1",
{% endif -%}
]

{% if include_pytest -%}
[tool.pytest.ini_options]
testpaths = ["tests"]
{% endif %}

{% if include_ruff -%}
[tool.ruff]
line-length = 100
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
{% endif %}

{% if include_mypy -%}
[tool.mypy]
python_version = "{{ python_version }}"
strict = true
pretty = true
{% endif %}
