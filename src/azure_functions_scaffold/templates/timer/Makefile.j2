VENV_DIR := .venv
PYTHON := $(VENV_DIR)/bin/python
PIP := $(VENV_DIR)/bin/pip

.PHONY: bootstrap
bootstrap:
	@if [ ! -d "$(VENV_DIR)" ]; then \
		python3 -m venv $(VENV_DIR); \
	fi
	@$(PIP) install --upgrade pip

.PHONY: install
install: bootstrap
	@$(PIP) install -e .{% if include_ruff or include_mypy or include_pytest %}[dev]{% endif %}

.PHONY: lint
lint:
{% if include_ruff -%}
	@$(VENV_DIR)/bin/ruff check .
	@$(VENV_DIR)/bin/ruff format --check .
{% else -%}
	@echo "No lint tooling configured."
{% endif %}

.PHONY: typecheck
typecheck:
{% if include_mypy -%}
	@$(VENV_DIR)/bin/mypy .
{% else -%}
	@echo "No type checker configured."
{% endif %}

.PHONY: test
test:
{% if include_pytest -%}
	@$(VENV_DIR)/bin/pytest
{% else -%}
	@echo "No test suite configured."
{% endif %}

.PHONY: check-all
check-all: lint typecheck test

